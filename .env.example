# Copy this file to .env and fill in real values. .env is gitignored and must
# never be committed. All secrets are read from the environment; nothing is
# hardcoded in the repository.

# --- LLM (generation) ---
# API key and base URL for the chat/completion LLM (OpenAI-compatible endpoint).
POLARIS_LLM_API_KEY=your_api_key_here
POLARIS_LLM_API_BASE=https://your-llm-endpoint/v1

# --- Embeddings ---
# Base URL of the text-embeddings service (e.g. a local TEI server).
EMBED_API_BASE=http://localhost:8080

# --- Jira ingestion ---
# API token used as the password for the Jira REST API. The username is set in
# the config (jira.username), not here.
JIRA_API_TOKEN=your_jira_api_token_here

# --- Hugging Face (model downloads) ---
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
# Optional separate token used by the evaluation/test config.
HF_TOKEN_TEST=

# --- Gemini (optional evaluator/generator) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- MLflow tracking ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Application / runtime ---
# Path to the active config file (defaults to config/config.yaml if unset).
POLARIS_CONFIG=config/config.yaml
# Display name shown in the UI.
POLARIS_DISPLAY_NAME=Polaris
# Where UI feedback is written.
POLARIS_FEEDBACK_LOG_PATH=data/ui_feedback/feedback.jsonl
# Comma-separated list of allowed CORS origins for the API.
POLARIS_UI_CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Gaudi (HPU) deployment only ---
# Habana HPU device indices for the embedding replicas in
# docker-compose.gaudi.yaml. Ignore these for the standard CPU/GPU setup.
EMBED_HPU=0
EMBED1_HPU=1
EMBED2_HPU=2
EMBED3_HPU=3
EMBED4_HPU=4
EMBED5_HPU=5
EMBED6_HPU=6
